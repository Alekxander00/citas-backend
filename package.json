{
  "name": "agendamiento-backend",
  "version": "1.0.0",
  "description": "Backend para sistema de agendamiento de citas médicas",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "node prisma/seed.js",
    "deploy": "npm run prisma:generate && npm run prisma:migrate && npm run prisma:seed"
  },
  "prisma": {
    "seed": "node prisma/seed.js"  
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "prisma": "^5.22.0"
  }
}