generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoIdentificacion {
  CEDULA_CIUDADANIA
  CEDULA_EXTRANJERIA
  CERTIFICADO_NACIDO_VIVO
  PERMISO_ESPECIAL_PERMANENCIA
  PERMISO_POR_PROTECCION_TEMPORAL
  REGISTRO_CIVIL
  TARJETA_IDENTIDAD
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

enum Jornada {
  MANANA
  TARDE
}

model Especialidad {
  codigo Int    @id @unique
  nombre String @unique
  icono  String @default("FaStethoscope")
  
  citas Cita[]
  
  @@map("especialidades")
}

model Cita {
  codigo_cita           String             @id @default(uuid()) @db.Uuid
  tipo_identificacion   TipoIdentificacion
  numero_identificacion String
  telefono              String
  especialidad_codigo   Int
  motivo_consulta       String?            @db.Text
  dia_semana            DiaSemana
  jornada               Jornada
  orden_pdf             Bytes              // ← QUITAR @db.Bytea
  created_at            DateTime           @default(now())
  
  especialidad Especialidad @relation(fields: [especialidad_codigo], references: [codigo], onDelete: Cascade)
  
  @@map("citas")
}

model DiaHabil {
  dia_semana      DiaSemana @id
  habilitado      Boolean   @default(true)
  mensaje_inhabil String?   @db.Text
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@map("dias_habiles")
}
